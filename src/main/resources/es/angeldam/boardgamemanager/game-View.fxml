<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="es.angeldam.boardgamemanager.controllers.subcontrollers.GameController"
           prefHeight="400.0" prefWidth="600.0"
           dividerPositions="0.145">
    <items>
        <AnchorPane maxWidth="150.0" minHeight="0.0" minWidth="150.0" prefWidth="150.0">
            <children>
                <Button fx:id="editGameButton" disable="true" layoutX="25.0" layoutY="70.0" mnemonicParsing="false"
                        onAction="#editGame" text="Edit Game"/>
                <Button fx:id="removeGameButton" disable="true" layoutX="14.0" layoutY="116.0" mnemonicParsing="false"
                        onAction="#removeGame" text="Remove Game"/>
                <Button fx:id="addGameButton" layoutX="24.0" layoutY="23.0" mnemonicParsing="false" onAction="#addGame"
                        text="Add Game"/>
            </children>
        </AnchorPane>
        <ScrollPane prefHeight="200.0" prefWidth="200.0">
            <content>
                <AnchorPane minHeight="0.0" minWidth="0.0">
                    <children>
                        <TextField fx:id="searchGameField" layoutX="134.0" layoutY="15.0"/>
                        <Label layoutX="14.0" layoutY="19.0" text="Search Game:"/>
                        <TableView fx:id="gameTable" layoutX="14.0" layoutY="56.0" prefHeight="280.0" prefWidth="912.0">
                            <columns>
                                <TableColumn fx:id="gCodeCol" prefWidth="86.0" text="Code"/>
                                <TableColumn fx:id="gBoardGameCol" prefWidth="129.0" text="Board Game"/>
                                <TableColumn fx:id="gPlaceCol" prefWidth="304.0" text="Place"/>
                                <TableColumn fx:id="gGameDateCol" prefWidth="147.0" text="GameDate"/>
                                <TableColumn fx:id="gPlayersCol" prefWidth="244.0" text="Players"/>
                            </columns>
                        </TableView>
                    </children>
                </AnchorPane>
            </content>
        </ScrollPane>
    </items>
</SplitPane>