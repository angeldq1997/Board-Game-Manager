<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<SplitPane dividerPositions="0.144" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="es.angeldam.boardgamemanager.controllers.subcontrollers.PlayerController">
    <items>
        <AnchorPane>
            <children>
                <Button fx:id="editPlayerButton" disable="true" layoutX="25.0" layoutY="70.0" mnemonicParsing="false"
                        onAction="#editPlayer" text="Edit Player"/>
                <Button fx:id="removePlayerButton" disable="true" layoutX="14.0" layoutY="116.0" mnemonicParsing="false"
                        onAction="#removePlayer" text="Remove Player"/>
                <Button fx:id="addPlayerButton" layoutX="24.0" layoutY="23.0" mnemonicParsing="false"
                        onAction="#addPlayer" text="Add Player"/>
            </children>
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </padding>
        </AnchorPane>
        <ScrollPane>
            <content>
                <AnchorPane>
                    <children>
                        <TextField fx:id="searchPlayerField" layoutX="134.0" layoutY="15.0"/>
                        <Label layoutX="14.0" layoutY="19.0" text="Search Player:"/>
                        <TableView fx:id="playerTable" layoutX="14.0" layoutY="56.0">
                            <columns>
                                <TableColumn fx:id="playerCodeCol" prefWidth="75.0" text="Code"/>
                                <TableColumn fx:id="playerNameCol" minWidth="100.0" prefWidth="249.0" text="Name"/>
                                <TableColumn fx:id="playerBirthYearCol" minWidth="40.0" prefWidth="120.0"
                                             text="Birth year"/>
                            </columns>
                        </TableView>
                    </children>
                </AnchorPane>
            </content>
        </ScrollPane>
    </items>
</SplitPane>
