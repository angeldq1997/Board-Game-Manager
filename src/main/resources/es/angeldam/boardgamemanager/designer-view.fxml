<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="designerTab" minHeight="0.0" minWidth="0.0" prefHeight="400.0"
            prefWidth="1100.0" xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="es.angeldam.boardgamemanager.controllers.DesignerController">
    <children>
        <SplitPane dividerPositions="0.14381818181818182" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0"
                   prefWidth="1100.0">
            <items>
                <AnchorPane maxWidth="150.0" minHeight="0.0" minWidth="150.0" prefWidth="150.0">
                    <children>
                        <Button fx:id="editDesignerButton" disable="true" layoutX="25.0" layoutY="70.0"
                                mnemonicParsing="false" onAction="#editDesigner" text="Edit Designer"/>
                        <Button fx:id="removeDesignerButton" disable="true" layoutX="14.0" layoutY="116.0"
                                mnemonicParsing="false" onAction="#removeDesigner" text="Remove Designer"/>
                        <Button fx:id="addDesignerButton" layoutX="24.0" layoutY="23.0" mnemonicParsing="false"
                                onAction="#addDesigner" text="Add Designer"/>
                    </children>
                </AnchorPane>
                <ScrollPane prefHeight="200.0" prefWidth="200.0">
                    <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0">
                            <children>
                                <TextField fx:id="searchDesigner" layoutX="134.0" layoutY="15.0"
                                           onAction="#searchDesigner"/>
                                <Label layoutX="14.0" layoutY="19.0" text="Search Designer:"/>
                                <TableView fx:id="designerTable" layoutX="14.0" layoutY="56.0" prefHeight="280.0"
                                           prefWidth="912.0">
                                    <columns>
                                        <TableColumn fx:id="dNameCol" prefWidth="162.3999605178833" text="Name"/>
                                        <TableColumn fx:id="dAliasCol" prefWidth="120.0" text="Alias"/>
                                        <TableColumn fx:id="dBirthDateCol" prefWidth="117.0" text="Birth date"/>
                                        <TableColumn fx:id="dNationalityCol" prefWidth="101.0" text="Nationality"/>
                                        <TableColumn fx:id="dBGCol" prefWidth="471.0" text="Board games"/>
                                    </columns>
                                </TableView>
                            </children>
                        </AnchorPane>
                    </content>
                </ScrollPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>