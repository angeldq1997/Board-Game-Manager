<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane minHeight="-Infinity" minWidth="-Infinity" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <bottom>
      <HBox alignment="CENTER" minHeight="-Infinity" minWidth="-Infinity" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="addGameButton" mnemonicParsing="false" onAction="#addGame" text="Add Game">
               <HBox.margin>
                  <Insets right="10.0" />
               </HBox.margin></Button>
            <Button fx:id="editGameButton" disable="true" mnemonicParsing="false" onAction="#editGame" text="Edit Game">
               <HBox.margin>
                  <Insets right="10.0" />
               </HBox.margin></Button>
            <Button fx:id="removeGameButton" disable="true" mnemonicParsing="false" onAction="#removeGame" text="Remove Game">
               <HBox.margin>
                  <Insets />
               </HBox.margin></Button>
         </children>
         <padding>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </padding>
         <BorderPane.margin>
            <Insets bottom="4.0" top="4.0" />
         </BorderPane.margin>
      </HBox>
   </bottom>
   <center>
      <ScrollPane minHeight="-Infinity" minWidth="-Infinity" BorderPane.alignment="CENTER">
         <content>
            <AnchorPane minHeight="0.0" minWidth="0.0">
               <children>
                  <TextField fx:id="searchGameField" layoutX="134.0" layoutY="15.0" />
                  <Label layoutX="14.0" layoutY="19.0" text="Search Game:" />
                  <TableView fx:id="gameTable" layoutX="14.0" layoutY="56.0" minHeight="-Infinity" minWidth="-Infinity">
                     <columns>
                        <TableColumn fx:id="gCodeCol" prefWidth="86.0" text="Code" />
                        <TableColumn fx:id="gBoardGameCol" prefWidth="129.0" text="Board Game" />
                        <TableColumn fx:id="gPlaceCol" prefWidth="304.0" text="Place" />
                        <TableColumn fx:id="gGameDateCol" prefWidth="147.0" text="GameDate" />
                        <TableColumn fx:id="gPlayersCol" prefWidth="244.0" text="Players" />
                     </columns>
                  </TableView>
               </children>
            </AnchorPane>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
