<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" spacing="10"
      styleClass="panel-box" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="es.angeldam.boardgamemanager.controllers.subcontrollers.FormEntityController">

    <padding>
        <Insets bottom="15" left="15" right="15" top="15"/>
    </padding>

    <Label fx:id="formTitleLabel" text="New Entity">
        <styleClass>
            <String fx:value="section-title"/>
            <String fx:value="h3"/>
        </styleClass>
    </Label>

    <GridPane hgap="10" minHeight="-Infinity" minWidth="-Infinity" vgap="12">
        <columnConstraints>
            <ColumnConstraints/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label styleClass="field-label" text="Name:" GridPane.rowIndex="0"/>

        <Label styleClass="field-label" text="Alias:" visible="false" GridPane.rowIndex="1"/>
        <Label styleClass="field-label" text="Birth year:" GridPane.rowIndex="2"/>
        <Label styleClass="field-label" text="Foundation year:" visible="false" GridPane.rowIndex="3"/>
        <Label styleClass="field-label" text="Nationality:" GridPane.rowIndex="4"/>
        <Label styleClass="field-label" text="Headquarters:" GridPane.rowIndex="5"/>

        <Label styleClass="field-label" text="Board Game:" GridPane.rowIndex="6"/>
        <TextField fx:id="txtName" promptText="Enter a name" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <TextField fx:id="txtAlias" promptText="Enter alias" visible="false" GridPane.columnIndex="1"
                   GridPane.rowIndex="1"/>
        <TextField fx:id="txtYear" promptText="Enter year of birth" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <TextField fx:id="txtPublicationYear" promptText="Enter foundation year" visible="false"
                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <TextField fx:id="txtNationality" promptText="Enter nationality" GridPane.columnIndex="1"
                   GridPane.rowIndex="4"/>
        <TextField fx:id="txtHeadquarters" promptText="Enter headquarters" GridPane.columnIndex="1"
                   GridPane.rowIndex="5"/>
        <HBox minHeight="-Infinity" minWidth="-Infinity" GridPane.columnIndex="1" GridPane.rowIndex="6">
            <children>
                <ComboBox fx:id="cmbBoardGame" minHeight="-Infinity" minWidth="-Infinity"
                          promptText="Select Board game">
                    <HBox.margin>
                        <Insets right="7.0"/>
                    </HBox.margin>
                </ComboBox>
                <Button mnemonicParsing="false" onAction="#addBoardGameToEntity" text="+"/>
            </children>
            <GridPane.margin>
                <Insets/>
            </GridPane.margin>
        </HBox>
        <rowConstraints>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="-Infinity"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
        </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER" spacing="10">
        <Button contentDisplay="CENTER" onAction="#closeWindow" text="Cancel">
            <styleClass>
                <String fx:value="btn"/>
                <String fx:value="btn-danger"/>
            </styleClass>
        </Button>
        <Button fx:id="btnSave" blendMode="DARKEN" contentDisplay="CENTER" defaultButton="true" onAction="#storeEntity"
                text="Save">
            <styleClass>
                <String fx:value="btn"/>
                <String fx:value="btn-success"/>
            </styleClass>
        </Button>
    </HBox>
</VBox>