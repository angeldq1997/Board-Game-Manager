<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="637.0" prefWidth="579.0" spacing="10"
      styleClass="panel-box" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="es.angeldam.boardgamemanager.controllers.subcontrollers.FormBoardGameController">

    <padding>
        <Insets bottom="15" left="15" right="15" top="15"/>
    </padding>

    <Label fx:id="formTitleLabel" text="New Board Game">
        <styleClass>
            <String fx:value="section-title"/>
            <String fx:value="h3"/>
        </styleClass>
    </Label>

    <GridPane hgap="10" prefHeight="532.0" prefWidth="390.0" vgap="12">
        <columnConstraints>
            <ColumnConstraints minWidth="90"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label styleClass="field-label" text="Name:" GridPane.rowIndex="0"/>
        <TextField fx:id="txtName" promptText="Enter a name" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label styleClass="field-label" text="Mechanics:" GridPane.rowIndex="1"/>

        <Label styleClass="field-label" text="Designer:" GridPane.rowIndex="9"/>
        <Label styleClass="field-label" text="Minimum players:" GridPane.rowIndex="2"/>
        <TextField fx:id="txtMinPlayers" promptText="Enter number" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label styleClass="field-label" text="Maximum players:" GridPane.rowIndex="3"/>
        <Label styleClass="field-label" text="Average duration:" GridPane.rowIndex="4"/>
        <Label styleClass="field-label" text="Recommended age:" GridPane.rowIndex="5"/>
        <Label styleClass="field-label" text="Publication year:" GridPane.rowIndex="6"/>
        <TextField fx:id="txtMaxPlayers" promptText="Enter number" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <TextField fx:id="txtAvgDuration" promptText="Enter number" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        <TextField fx:id="txtAge" promptText="Enter number" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
        <TextField fx:id="txtPubYear" promptText="Enter year" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
        <Label styleClass="field-label" text="Difficulty:" GridPane.rowIndex="7"/>
        <ComboBox fx:id="cmbDifficulty" prefHeight="26.0" prefWidth="130.0" promptText="Select a difficulty"
                  GridPane.columnIndex="1" GridPane.rowIndex="7"/>
        <Label styleClass="field-label" text="Ranking:" GridPane.rowIndex="8"/>
        <TextField fx:id="txtRanking" promptText="Enter number" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
        <Label styleClass="field-label" text="Illustrator:" GridPane.rowIndex="10"/>
        <Label styleClass="field-label" text="Publisher:" GridPane.rowIndex="11"/>
        <TextField fx:id="txtMechanics" promptText="Enter mechanics" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <HBox prefHeight="100.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="9">
            <children>
                <ComboBox fx:id="cmbDesigner1" prefWidth="150.0" promptText="Select Designer 1">
                    <HBox.margin>
                        <Insets right="7.0"/>
                    </HBox.margin>
                </ComboBox>
                <ComboBox fx:id="cmbDesigner2" disable="true" prefWidth="150.0" promptText="Select Designer 2"
                          visible="false">
                    <HBox.margin>
                        <Insets right="7.0"/>
                    </HBox.margin>
                </ComboBox>
                <ComboBox fx:id="cmbDesigner3" disable="true" prefWidth="150.0" promptText="Select Designer 3"
                          visible="false"/>
            </children>
            <GridPane.margin>
                <Insets/>
            </GridPane.margin>
        </HBox>
        <HBox prefHeight="100.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="10">
            <children>
                <ComboBox fx:id="cmbIllustrator1" prefWidth="150.0" promptText="Select Illustrator 1">
                    <HBox.margin>
                        <Insets right="7.0"/>
                    </HBox.margin>
                </ComboBox>
                <ComboBox fx:id="cmbIllustrator2" disable="true" prefWidth="150.0" promptText="Select Illustrator 2"
                          visible="false">
                    <HBox.margin>
                        <Insets right="7.0"/>
                    </HBox.margin>
                </ComboBox>
                <ComboBox fx:id="cmbIllustrator3" disable="true" prefWidth="150.0" promptText="Select Illustrator 3"
                          visible="false"/>
            </children>
        </HBox>
        <HBox prefHeight="100.0" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="11">
            <children>
                <ComboBox fx:id="cmbPublisher1" prefWidth="150.0" promptText="Select Publisher 1">
                    <HBox.margin>
                        <Insets right="7.0"/>
                    </HBox.margin>
                </ComboBox>
                <ComboBox fx:id="cmbPublisher2" disable="true" prefWidth="150.0" promptText="Select Publisher 2"
                          visible="false">
                    <HBox.margin>
                        <Insets right="7.0"/>
                    </HBox.margin>
                </ComboBox>
                <ComboBox fx:id="cmbPublisher3" disable="true" prefWidth="150.0" promptText="Select Publisher 3"
                          visible="false"/>
            </children>
        </HBox>
        <rowConstraints>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints minHeight="10.0" prefHeight="30.0"/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
            <RowConstraints/>
        </rowConstraints>
    </GridPane>

    <HBox alignment="CENTER" spacing="10">
        <Button contentDisplay="CENTER" onAction="#closeWindow" text="Cancel">
            <styleClass>
                <String fx:value="btn"/>
                <String fx:value="btn-danger"/>
            </styleClass>
        </Button>
        <Button fx:id="btnSave" blendMode="DARKEN" contentDisplay="CENTER" defaultButton="true"
                onAction="#storeBoardGame" text="Save">
            <styleClass>
                <String fx:value="btn"/>
                <String fx:value="btn-success"/>
            </styleClass>
        </Button>
    </HBox>
</VBox>
