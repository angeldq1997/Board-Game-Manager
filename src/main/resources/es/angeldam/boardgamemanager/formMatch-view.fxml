<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" styleClass="panel-box"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="es.angeldam.boardgamemanager.controllers.subcontrollers.FormMatchController">
    <children>
        <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" spacing="10"
              styleClass="panel-box">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15"/>
            </padding>
            <children>
                <Label fx:id="formTitleLabel" text="New match:">
                    <styleClass>
                        <String fx:value="section-title"/>
                        <String fx:value="h3"/>
                    </styleClass>
                </Label>
                <GridPane hgap="10" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints minHeight="-Infinity"/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                        <RowConstraints/>
                    </rowConstraints>
                    <children>
                        <Label styleClass="field-label" text="Place:" GridPane.rowIndex="0"/>
                        <TextField fx:id="txtPlace" promptText="Enter a place" GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>
                        <Label styleClass="field-label" text="Date:" GridPane.rowIndex="1"/>
                        <Label styleClass="field-label" text="Board Game:" GridPane.rowIndex="2"/>
                        <ComboBox fx:id="cmbBoardGame" minHeight="-Infinity" minWidth="-Infinity"
                                  promptText="Select board game" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </children>
                </GridPane>
                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Button contentDisplay="CENTER" onAction="#closeWindow" text="Cancel">
                            <styleClass>
                                <String fx:value="btn"/>
                                <String fx:value="btn-danger"/>
                            </styleClass>
                        </Button>
                        <Button fx:id="btnSave" blendMode="DARKEN" contentDisplay="CENTER" defaultButton="true"
                                onAction="#storeMatch" text="Save">
                            <styleClass>
                                <String fx:value="btn"/>
                                <String fx:value="btn-success"/>
                            </styleClass>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</HBox>
